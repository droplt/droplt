{
  "name": "@droplt/droplt",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "lint": "turbo run lint",
    "prepare": "husky install",
    "style": "prettier --check \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "@commitlint/cli": "17.8.0",
    "@commitlint/config-conventional": "17.8.0",
    "eslint": "8.51.0",
    "husky": "8.0.3",
    "lint-staged": "15.0.1",
    "prettier": "3.0.3",
    "prettier-plugin-packagejson": "2.4.6",
    "tsconfig": "workspace:*",
    "turbo": "latest"
  },
  "packageManager": "pnpm@8.6.10"
}
